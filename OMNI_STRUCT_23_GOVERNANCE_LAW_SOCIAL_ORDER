        if user_baseline and self.is_anomalous(access_context, user_baseline):
            anomaly = {
                'user_id': user_id,
                'asset_id': asset_id,
                'context': access_context,
                'deviation_from_baseline': self.calc_deviation(access_context, user_baseline),
                'risk_factors': self.identify_risk_factors(user_id, access_context)
            }
            
            if self.inner_ai_core.validate_privacy_preservation(anomaly, self.privacy_threshold):
                self.trigger_human_gate(anomaly)
            
            return anomaly
        
        return None
