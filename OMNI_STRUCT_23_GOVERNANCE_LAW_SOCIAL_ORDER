4.3 Immutable Decision Governance Ledger (IDGL)

```python
class Domain23_ImmutableDecisionGovernanceLedger:
    """
    Immutable Decision Governance Ledger.
    מתעד תהליכי קבלת החלטות עם הקשר מלא בשכבה בלתי-מחיקה.
    """
    def __init__(self):
        self.ledger = ImmutableLedger()
        self.vsci_agents = VSCIAgentCluster()
    
    def record_decision_process(self, decision_context):
        alternatives = decision_context.alternatives
        intents = [self.vsci_agents.reflect_intent(alt.rationale) for alt in alternatives]
        harmony_scores = [self.calc_harmony(intent, alt.friction) for intent, alt in zip(intents, alternatives)]
        
        entry = {
            'timestamp': now(),
            'decision_makers': decision_context.participants,
            'alternatives_considered': [
                {'description': alt.description, 'intent': intent, 'harmony_score': score}
                for alt, intent, score in zip(alternatives, intents, harmony_scores)
            ],
            'chosen_alternative': decision_context.chosen,
            'ethical_validation': self.inner_ai_core.validate_decision(decision_context.chosen),
            'dissenting_opinions': decision_context.dissents
        }
        
        self.ledger.append_immutable(entry)
        return entry.id
    
    def reconstruct_decision(self, decision_id):
        return self.ledger.retrieve(decision_id)
